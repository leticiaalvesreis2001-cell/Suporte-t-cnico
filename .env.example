# ─── FUTURAS INTEGRAÇÕES DE API ─────────────────────────────
# Firebase (caso integre no futuro)
# FIREBASE_API_KEY=sua_chave_aqui
# FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
# FIREBASE_PROJECT_ID=seu-projeto-id
# FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
# FIREBASE_MESSAGING_SENDER_ID=000000000000
# FIREBASE_APP_ID=1:000000000000:web:abc123

# Supabase (caso integre no futuro)
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=sua_chave_publica_aqui

# API REST Backend (caso integre no futuro)
# API_BASE_URL=https://api.suaempresa.com.br/v1
# API_SECRET_KEY=sua_chave_secreta_aqui

# ─── CONFIGURAÇÕES DA APLICAÇÃO ─────────────────────────────
# APP_ENV=development
# APP_NAME=TechSupport Ops
