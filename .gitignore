# ============================================================
# .gitignore — TechSupport Ops
# Arquiteto: Antigravity | Stack: HTML + CSS + Vanilla JS
# ============================================================

# ─── SISTEMA OPERACIONAL ────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encdata
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.Spotlight-V100
.Trashes

# Linux
*~

# ─── EDITORES E IDEs ────────────────────────────────────────
# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# ─── VARIÁVEIS DE AMBIENTE E SEGREDOS ───────────────────────
# NUNCA versionar estes arquivos!
.env
.env.local
.env.development
.env.staging
.env.production
.env.*.local
*.pem
*.key
*.p12
*.pfx
secrets.json
secrets.yaml
secrets.yml

# ─── NODE.JS (para futuras integrações) ─────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.pnpm-store/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── BUILD E DISTRIBUIÇÃO ───────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.vite/

# ─── LOGS ───────────────────────────────────────────────────
logs/
*.log
*.log.*

# ─── ARQUIVOS TEMPORÁRIOS ───────────────────────────────────
*.tmp
*.temp
*.swp
*.bak
*.orig
~$*

# ─── PASTA DE STITCH (protótipos gerados) ───────────────────
# Pasta de rascunhos/protótipos — não faz parte do código-fonte final
stitch_dashboard_de_suporte_integrado/

# ─── COBERTURA DE TESTES ────────────────────────────────────
coverage/
.nyc_output/

# ─── MISC ───────────────────────────────────────────────────
.gemini/
*.zip
*.tar.gz
*.rar
